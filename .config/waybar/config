
{
    "layer": "top",
    "position": "top",
    "height": 40,
    "margin-top": 0,
    "margin-left": 10,
    "margin-right": 10,

    "modules-left": ["niri/workspaces", "niri/window" ],
    "modules-center": ["mpris", "clock", "cpu", "memory", "custom/fan",],
    "modules-right": ["network", "pulseaudio", "battery", "tray" ],

    "niri/workspaces": {
        "format": "{index} <span color='#585b70'>:</span> {icon}",
        "format-icons": {
            "default": "󰊠",
            "focused": "󰮯",
            "urgent": "󰀨"
        }
    },

    "niri/window": {
        "format": "{title}",
        "max-length": 35,
        "separate-outputs": true
    },

    "mpris": {
        "format": "󰏤 {title}",
        "format-paused": "󰐊 {title}",
        "max-length": 25,
        "interval": 0.8, 
        "on-click": "playerctl play-pause",
        "on-scroll-down": "playerctl next",
        "on-scroll-up": "playerctl previous"
    },

    "network": {
        "interval": 2,
        // "format-wifi": " {bandwidthDownBytes:3}  {bandwidthUpBytes:3}  <span size='large'></span>",
        // "format-ethernet": " {bandwidthDownBytes:3}  {bandwidthUpBytes:3} 󰈀",
	"format-wifi": "<span size='large'></span> {essid}",
        "format-disconnected": "󰖪 Off"
    },

    "cpu": {
        // {usage:2} 强制占2位，防止从 9% 变到 10% 时图标乱动
        "format": " {usage:>2}% 󰓅 {avg_frequency:>3}GHz",
        "interval": 2
    },

    "custom/fan": {
        "format": "󰈐 {}RPM",
        "interval": 2,
        "exec": "sensors | grep -i 'fan' | awk '{print $2}' | head -n 1",
        "tooltip": false
    },

    "memory": {
        "format": " {used:>0.1f}GiB({percentage:>2}%)",
        "interval": 2
    },

    "clock": {
        "format": "󰃭 {:%a %b %d  %H:%M:%S}",
        "interval": 1
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-icons": ["󰕿", "󰖀", "󰕾"]
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"]
    },

    "tray": {
        "icon-size": 25,
        "spacing": 10
    }
}
