{
    "layer": "top",
    "position": "top",
    "height": 34,
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,

    "modules-left": ["niri/workspaces", "niri/window"],
    "modules-center": ["clock", "cpu", "custom/fan", "memory", "network", "pulseaudio", "battery"],
    "modules-right": ["tray"],

    "niri/workspaces": {
        "format": "{index} <span color='#585b70'>:</span> {icon}",
        "format-icons": {
            "default": "≤░Λι",
            "focused": "≤░χψ",
            "urgent": "≤░Αρ"
        }
    },

    "niri/window": {
        "format": "{title}",
        "max-length": 35,
        "separate-outputs": true
    },

    "network": {
        "interval": 2,
        "format-wifi": "ΎΒμ {bandwidthDownBytes:3} ΎΒλ {bandwidthUpBytes:3}  <span size='large'>ΎΘτ</span>",
        "format-ethernet": "ΎΒμ {bandwidthDownBytes:3} ΎΒλ {bandwidthUpBytes:3} ≤░ΙΑ",
        "format-disconnected": "≤░Ψς Off"
    },

    "cpu": {
        "format": "ΎΤ╝ {usage}% <span color='#585b70'>@</span> {avg_frequency}GHz",
        "interval": 2
    },

    "custom/fan": {
        "format": "≤░ΙΡ {} RPM",
        "interval": 2,
        "exec": "sensors | grep -i 'fan' | awk '{print $2}' | head -n 1",
        "tooltip": false
    },

    "memory": {
        "format": "ΌΚο {percentage}%",
        "interval": 2
    },

    "clock": {
        "format": "≤░Δφ {:%a %b %d  %H:%M:%S}",
        "interval": 1
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-icons": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"]
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"]
    },

    "tray": {
        "icon-size": 25,
        "spacing": 10
    }
}
