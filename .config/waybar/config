
{
    "layer": "top",
    "position": "top",
    "height": 40,
    "margin-top": 0,
    "margin-left": 10,
    "margin-right": 10,

    "modules-left": ["custom/overview-icon", "niri/workspaces", "niri/window" ],
    "modules-center": ["mpris", "clock", "cpu", "memory", "custom/fan",],
    "modules-right": ["network", "pulseaudio", "battery", "tray" ],

    "custom/overview-icon": {
        "format": "≤░Χ░", 
	"on-click": "niri msg action toggle-overview",
	"on-click-right": "pkill wofi || wofi --show drun --location top_left --xoffset 50 --yoffset 50",
    },

    "niri/workspaces": {
        "format": "{index}<span color='#585b70'>:</span>{icon}",
        "format-icons": {
            "default": "≤░Λι",
            "focused": "≤░χψ",
            "urgent": "≤░Αρ"
        }
    },

    "niri/window": {
        "format": "{title}",
        "max-length": 35,
        "separate-outputs": true
    },

    "mpris": {
        "format": "≤░Πν {title}",
        "format-paused": "≤░ΡΛ {title}",
        "max-length": 25,
        "interval": 0.8, 
        "on-click": "playerctl play-pause",
        "on-scroll-down": "playerctl next",
        "on-scroll-up": "playerctl previous"
    },

    "network": {
        "interval": 2,
        // "format-wifi": "ΎΒμ {bandwidthDownBytes:3} ΎΒλ {bandwidthUpBytes:3}  <span size='large'>ΎΘτ</span>",
        // "format-ethernet": "ΎΒμ {bandwidthDownBytes:3} ΎΒλ {bandwidthUpBytes:3} ≤░ΙΑ",
	"format-wifi": "<span size='large'>ΎΘτ</span> {essid}",
        "format-disconnected": "≤░Ψς Off"
    },

    "cpu": {
        "format": "ΎΤ╝ {usage:>2}% ≤░ΥΖ {avg_frequency:>3}GHz",
        "interval": 2
    },

    "custom/fan": {
        "format": "≤░ΙΡ {}RPM",
        "interval": 2,
        "exec": "sensors | grep -i 'fan' | awk '{print $2}' | head -n 1",
        "tooltip": false
    },

    "memory": {
        "format": "ΌΚο {used:>0.1f}GiB({percentage:>2}%)",
        "interval": 2
    },

    "clock": {
        "format": "≤░Δφ {:%a %b %d  %H:%M:%S}",
        "interval": 1
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-icons": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"]
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"]
    },

    "tray": {
        "icon-size": 25,
        "spacing": 10
    }
}
